# Ưu tiên MySQL theo báo cáo
# Ví dụ:
# DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/boarding_house

DATABASE_URL=mysql+pymysql://root:123456@localhost:3306/boarding_house
APP_NAME=Hệ thống quản lý giá phòng trọ và gợi ý giá thuê
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123
ADMIN_FULL_NAME=Chủ trọ mặc định

# === Cấu hình MoMo QR tĩnh ===
MOMO_PHONE=0909000000
MOMO_NAME=Chu Tro

# === Cấu hình MoMo API (Tự động thanh toán) ===
# Đăng ký tại https://business.momo.vn để lấy credentials
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENV=sandbox  # sandbox hoặc production
MOMO_REDIRECT_URL=http://localhost:8501/payment/callback
MOMO_IPN_URL=http://localhost:8501/payment/ipn

# === Cấu hình chuyển khoản ngân hàng (VietQR) ===
# BANK_NAME  : Mã ngân hàng VietQR. VD: VCB, TCB, MB, ACB, VPB, ...
# Xem danh sách đầy đủ tại https://api.vietqr.io/v2/banks
BANK_ACCOUNT_NO=1234567890
BANK_NAME=VCB
BANK_ACCOUNT_NAME=Chu Tro

# === Gemini AI ===
GEMINI_API_KEY=
